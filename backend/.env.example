# ─── Backend Environment Variables ────────────────────
# Copy this file to .env and fill in your real values.

# PostgreSQL connection string from Render (set automatically when you add a DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Change this to your Vercel frontend URL after deploying
GOOGLE_REDIRECT_URI=https://your-frontend.vercel.app/auth/callback

# OpenRouter AI (get key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_MODEL=mistralai/mistral-7b-instruct
BACKUP_MODEL=meta-llama/llama-3-8b-instruct

# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret
